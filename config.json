{
  "photoDirectory": "/Volumes/1tb/all-pics/",
  "databasePath": "./data/pictureframe.db",
  "serverPort": 3000,
  "slideshow": {
    "defaultInterval": 10,
    "defaultMode": "sequential",
    "defaultOrder": "date",
    "numberOfImagesToPreload": 15
  },
  "fileExtensions": [".jpg", ".jpeg", ".png", ".gif", ".webp", ".heic", ".heif"],
  "indexing": {
    "batchSize": 100,
    "logInterval": 500
  },
  "watcher": {
    "usePolling": false
  },
  "resize": {
    "maxWidth": 3840,
    "maxHeight": 2160,
    "runOnStartup": true
  }
}


